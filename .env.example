# ─── Base de Datos ───────────────────────────────────────────────────────────
# Ruta al archivo SQLite.
# En Docker (producción): file:/data/db.sqlite  (montar /data como volumen)
DATABASE_URL="file:./dev.db"

# ─── Better Auth ─────────────────────────────────────────────────────────────
# URL pública de la app (frontend). Se usa para CORS y trusted origins.
# En producción: la URL pública del servidor (ej. https://app.example.com)
BETTER_AUTH_URL="http://localhost:4321"

# Clave secreta para firmar sesiones y tokens.
# Genera una segura con: openssl rand -base64 32
BETTER_AUTH_SECRET="change-me-in-production"

# ─── Admin inicial ────────────────────────────────────────────────────────────
# El usuario admin se crea automáticamente al arrancar si no existe.
SEED_ADMIN_EMAIL="admin@example.com"
SEED_ADMIN_NAME="Admin"
SEED_ADMIN_PASSWORD="change-me-in-production"

# ─── SSO / Keycloak (opcional) ───────────────────────────────────────────────
SSO_CLIENT_ID=""
SSO_CLIENT_SECRET=""
# Discovery URL del realm: https://keycloak.example.com/realms/<realm>
SSO_ISSUER=""
