DATABASE_URL="postgresql://postgres:postgres@localhost:5432/postgres"

BETTER_AUTH_URL="http://localhost:4321"
BETTER_AUTH_SECRET="secret-key-change-in-production"

# Google OAuth (optional)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# SSO Authentik Configuration
SSO_SLUG_APP="your-app-slug"
SSO_BASE_URL="https://your-sso-server.com"
SSO_CLIENT_ID="your-client-id"
SSO_CLIENT_SECRET="your-client-secret"
SSO_DOMAIN="your-domain.com"

# Seed User Configuration (for development)
SEED_ADMIN_EMAIL="admin@example.com"
SEED_ADMIN_NAME="admin"
SEED_ADMIN_PASSWORD="your-secure-password"
